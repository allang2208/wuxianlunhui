{
  "appId": "com.yourname.wuxian-lunhui",
  "productName": "无限轮回",
  "directories": {
    "output": "dist-electron-new"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "build/**/*"
  ],
  "extraResources": [
    {
      "from": "assets",
      "to": "assets"
    }
  ],
  "asar": false,
  "npmRebuild": false,
  "nodeGypRebuild": false,
  "win": {
    "target": "portable",
    "icon": "build/app-icon.png",
    "signAndEditExecutable": false
  },
  "electronDist": "node_modules/electron/dist"
}